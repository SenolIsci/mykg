    rdfs:domain ex:Team ;
    rdfs:range  rdfs:Literal .
ex:description rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  rdfs:Literal .
ex:member_count rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:status rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:target_completion_date rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:budget rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:type rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:version rdf:type rdf:Property ;
    rdfs:domain ex:Technology ;
    rdfs:range  rdfs:Literal .
ex:description rdf:type rdf:Property ;
    rdfs:domain ex:Product ;
    rdfs:range  rdfs:Literal .
ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Agreement ;
    rdfs:range  rdfs:Literal .
ex:type rdf:type rdf:Property ;
    rdfs:domain ex:Agreement ;
    rdfs:range  rdfs:Literal .
ex:start_date rdf:type rdf:Property ;
    rdfs:domain ex:Agreement ;
    rdfs:range  rdfs:Literal .

ex:works_at rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Organization .
ex:manages rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Team .
ex:member_of rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Team .
ex:reports_to rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Person .
ex:leads rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Project .
ex:contributes_to rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Project .
ex:owns rdf:type rdf:Property ;
    rdfs:domain ex:Team ;
    rdfs:range  ex:Project .
ex:depends_on rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  ex:Project .
ex:uses_technology rdf:type rdf:Property ;
    rdfs:domain ex:Project ;
    rdfs:range  ex:Technology .
ex:provides rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Product .
ex:has_partnership rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Organization .
ex:vendor_for rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Organization .
ex:has_agreement rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  ex:Agreement .
ex:account_manager_for rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Organization .
ex:co_founded rdf:type rdf:Property ;
    rdfs:domain ex:Person ;
    rdfs:range  ex:Organization .
ex:supports rdf:type rdf:Property ;
    rdfs:domain ex:Agreement ;
    rdfs:range  ex:Project .

