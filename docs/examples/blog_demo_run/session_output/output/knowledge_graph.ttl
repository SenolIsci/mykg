@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://mykg.local/schema/> .
@prefix data: <http://mykg.local/data/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ==========================================
# 1. THE RDFS SCHEMA (TBox)
# ==========================================

ex:Organization rdf:type rdfs:Class .
ex:Company rdf:type rdfs:Class .
ex:Person rdf:type rdfs:Class .
ex:Employee rdf:type rdfs:Class .
ex:Team rdf:type rdfs:Class .
ex:Project rdf:type rdfs:Class .
ex:Technology rdf:type rdfs:Class .
ex:Product rdf:type rdfs:Class .
ex:Agreement rdf:type rdfs:Class .

ex:Company rdfs:subClassOf ex:Organization .
ex:Employee rdfs:subClassOf ex:Person .
ex:Product rdfs:subClassOf ex:Technology .

ex:name rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:headquarters_location rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
ex:industry rdf:type rdf:Property ;
    rdfs:domain ex:Organization ;
    rdfs:range  rdfs:Literal .
